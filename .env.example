# Copy to .env and fill in. Loaded by your shell or a dotenv loader.

# Temporal connection (matches docker-compose defaults)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=agent-tasks

# Anthropic API key for the AI-agent activities
ANTHROPIC_API_KEY=sk-ant-...

# Model used by the agent activities
AGENT_MODEL=claude-opus-4-7
